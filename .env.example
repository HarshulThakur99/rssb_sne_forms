# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Flask Configuration
SECRET_KEY=generate_with_python_-c_import_secrets_print_secrets_token_hex_32
FLASK_ENV=production  # Use 'development' for local dev only
PORT=5000

# User Passwords - Use strong, unique passwords!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_PASSWORD=your_strong_admin_password_here
SNE_USER_PASSWORD=your_strong_sne_password_here
BAAL_SATSANG_PASSWORD=your_strong_baal_satsang_password_here
SEWA_BADGES_PASSWORD=your_strong_sewa_badges_password_here
BLOOD_CAMP_PASSWORD=your_strong_blood_camp_password_here

# AWS S3 Configuration
S3_BUCKET_NAME=rssbsne
# AWS credentials should be configured via IAM role (recommended) or AWS CLI

# Google Sheets Configuration
SNE_SHEET_ID=1M9dHOwtVldpruZoBzH23vWIVdcvMlHTdf_fWJGWVmLM
BLOOD_CAMP_SHEET_ID=1fkswOZnDXymKblLsYi79c1_NROn3mMaSua7u5hEKO_E
ATTENDANT_SHEET_ID=13kSQ28X8Gyyba3z3uVJfOqXCYM6ruaw2sIp-nRnqcrM

# Google Service Account Files (absolute paths to JSON files stored securely)
SNE_SERVICE_ACCOUNT_FILE=/etc/secrets/rssbsneform-credentials.json
BLOOD_CAMP_SERVICE_ACCOUNT_FILE=/etc/secrets/grand-nimbus-credentials.json
ATTENDANT_SERVICE_ACCOUNT_FILE=/etc/secrets/grand-nimbus-credentials.json
